VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# External geocoding — Step 3 of the place location system.
# Provider: Geoapify (https://www.geoapify.com)
# Free tier: 3,000 requests/day — sufficient for personal use.
# Security: set HTTP Referrer restriction to your domain in the Geoapify dashboard
#           before deploying, e.g. https://your-domain.com/*
# Leave empty to keep the current "unsupported place" fallback message.
VITE_GEOAPIFY_API_KEY=
